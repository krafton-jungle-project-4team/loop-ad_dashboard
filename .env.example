NODE_ENV=development
LOOPAD_ENV=local
LOOPAD_SERVICE_ID=dashboard-api
PORT=8080
LOOPAD_API_HOST_PORT=3100
LOOPAD_API_PROXY_TARGET=http://api-server:8080
LOOPAD_SEED_DEMO_DATA=true
LOOPAD_AURORA_HOST=postgres
LOOPAD_AURORA_PORT=5432
LOOPAD_AURORA_HOST_PORT=15432
LOOPAD_AURORA_DATABASE=loopad
LOOPAD_AURORA_USERNAME=loopad
LOOPAD_AURORA_PASSWORD=change-me
LOOPAD_CLICKHOUSE_URL=http://clickhouse:8123
LOOPAD_CLICKHOUSE_HTTP_PORT=8123
LOOPAD_CLICKHOUSE_NATIVE_PORT=9000
LOOPAD_CLICKHOUSE_USERNAME=default
LOOPAD_DATA_STORAGE_BUCKET=loop-ad-local-dashboard-assets
LOOPAD_GENAI_GENERATED_ASSETS_PREFIX=genai/generated/
