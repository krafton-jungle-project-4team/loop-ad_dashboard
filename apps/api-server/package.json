{
  "name": "@loopad/api-server",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/main.ts",
    "build": "tsc -p tsconfig.json && node scripts/copy-static-assets.mjs",
    "db:generate": "pgtyped -c pgtyped.config.json",
    "start": "node dist/main.js",
    "test": "npm run build -w @loopad/shared && tsx --test \"tests/**/*.test.ts\"",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@aws-sdk/client-sesv2": "^3.1079.0",
    "@aws-sdk/client-sns": "^3.1079.0",
    "@clickhouse/client": "^1.14.0",
    "@loopad/shared": "file:../../packages/shared",
    "@nestjs-cls/transactional": "^3.2.1",
    "@nestjs/common": "^11.1.27",
    "@nestjs/core": "^11.1.27",
    "@nestjs/platform-express": "^11.1.27",
    "@pgtyped/runtime": "^2.4.2",
    "escape-html": "^1.0.3",
    "nestjs-cls": "^6.2.1",
    "pg": "^8.16.3",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.2",
    "serialize-javascript": "^7.0.7",
    "zod": "^4.2.1"
  },
  "devDependencies": {
    "@pgtyped/cli": "^2.4.3",
    "@types/escape-html": "^1.0.4",
    "@types/node": "^25.0.3",
    "@types/pg": "^8.16.0",
    "@types/serialize-javascript": "^5.0.4",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3"
  }
}
